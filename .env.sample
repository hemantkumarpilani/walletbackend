PORT=3000

# MongoDB connection URL (Atlas or local)
MONGO_URL=mongodb+srv://user:password@cluster.mongodb.net/dbname?appName=Cluster0

JWT_ACCESS_SECRET=your_access_secret
JWT_REFRESH_SECRET=your_refresh_secret

ACCESS_TOKEN_EXPIRES=1d
REFRESH_TOKEN_EXPIRES=30d

FIREBASE_PROJECT_ID=your_firebase_project_id
# FIREBASE_SERVICE_ACCOUNT_JSON='{"type":"service_account",...}'
# FIREBASE_SERVICE_ACCOUNT_BASE64=base64_encoded_service_account_json
# FIREBASE_SERVICE_ACCOUNT_FILE=./config/firebase-service-account.json

# Local/self-hosted model that extracts voice transaction drafts.
VOICE_LLM_BASE_URL=http://localhost:11434
VOICE_LLM_MODEL=qwen3:8b
VOICE_LLM_TIMEOUT_MS=30000

SENDGRID_API_KEY=your_sendgrid_api_key

EMAIL_FROM=your_email@gmail.com

# Optional inbox for help center, bug reports, and feature requests
SUPPORT_EMAIL=support@yourcompany.com

# RECOMMENDED for personal Gmail folders — OAuth uses YOUR Drive quota (not service account)
# 1) Google Cloud Console → APIs → OAuth client (Web application)
# 2) OAuth consent screen → add scope: https://www.googleapis.com/auth/drive.file
# 3) Get refresh token (OAuth Playground or one-time auth script) for the Gmail that owns the folder
GOOGLE_OAUTH_CLIENT_ID=your_client_id.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=your_client_secret
GOOGLE_DRIVE_REFRESH_TOKEN=your_refresh_token

# OPTIONAL — service account only works with Shared Drive (Google Workspace), NOT personal My Drive
# GOOGLE_APPLICATION_CREDENTIALS=./config/google-service-account.json

# cloudflare R2
R2_ACCESS_KEY_ID=YOUR_R2_ACCESS_KEY_ID
R2_SECRET_ACCESS_KEY=YOUR_R2_SECRET_ACCESS_KEY
R2_ENDPOINT=YOUR_R2_ENDPOINT
R2_BUCKET_NAME=YOUR_R2_BUCKET_NAME
R2_PUBLIC_BASE_URL=YOUR_PUBLIC_R2_BUCKET_OR_CUSTOM_DOMAIN_URL

# Stripe recurring subscriptions
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_signing_secret
STRIPE_PRICE_BASIC=price_your_basic_monthly_price_id
STRIPE_PRODUCT_BASIC=prod_your_basic_product_id
STRIPE_PRICE_PREMIUM=price_your_premium_monthly_price_id
STRIPE_PRODUCT_PREMIUM=prod_your_premium_product_id
STRIPE_PRICE_PREMIUM_PLUS=price_your_premium_plus_monthly_price_id
STRIPE_PRODUCT_PREMIUM_PLUS=prod_your_premium_plus_product_id
STRIPE_PRICE_PREMIUM_YEARLY=price_your_premium_yearly_price_id
STRIPE_PRODUCT_PREMIUM_YEARLY=prod_your_premium_yearly_product_id
STRIPE_PRICE_PREMIUM_PLUS_YEARLY=price_your_premium_plus_yearly_price_id
STRIPE_PRODUCT_PREMIUM_PLUS_YEARLY=prod_your_premium_plus_yearly_product_id
STRIPE_CHECKOUT_SUCCESS_URL=http://localhost:3000/subscription/success?session_id={CHECKOUT_SESSION_ID}
STRIPE_CHECKOUT_CANCEL_URL=http://localhost:3000/subscription/cancel

# Exchange rates — Currency Conversion and Exchange Rates (RapidAPI)
# https://rapidapi.com/principalapis/api/currency-conversion-and-exchange-rates
RAPIDAPI_KEY=your_rapidapi_key
EXCHANGE_RATE_BASE_CURRENCY=USD
EXCHANGE_RATE_API_HOST=currency-conversion-and-exchange-rates.p.rapidapi.com
EXCHANGE_RATE_API_URL=https://currency-conversion-and-exchange-rates.p.rapidapi.com/latest?base=USD

# Default admin account (created on server start if it does not exist)
ADMIN_USERNAME=admin@gmail.com
ADMIN_PASSWORD=admin@12345

# Admin key for PUT /api/app-settings (send as x-api-key header)
APP_SETTINGS_API_KEY=your_app_settings_admin_key
